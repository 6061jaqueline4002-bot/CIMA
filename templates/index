<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CIMA 🤝📌</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <style>
        
        body {
            background: linear-gradient(180deg, #002E5D 0%, #004B8D 100%);
            color: #fff;
            font-family: "Segoe UI", sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            padding: 10px;
        }

        .chat-container {
            width: 420px;
            max-width: 95%;
            background: #ffffff;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.3);
            display: flex;
            flex-direction: column;
            height: 95vh;
        }

        .chat-header {
            background: #004B8D;
            color: white;
            padding: 20px;
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            position: relative;
        }

        .chat-header::after {
            content: "👍";
            position: absolute;
            right: 20px;
            animation: hop 2s infinite ease-in-out;
        }

        @keyframes hop { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }

        .chat-box {
            background: #f9f9f9;
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            scroll-behavior: smooth;
        }

        .bot-message, .user-message {
            margin: 8px 0;
            padding: 12px 15px;
            border-radius: 15px;
            max-width: 85%;
            animation: pop 0.3s ease;
            line-height: 1.4;
        }

        @keyframes pop { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .bot-message {
            background: #E3F2FD;
            color: #004B8D;
            align-self: flex-start;
            box-shadow: 0 0 8px rgba(0, 75, 141, 0.2);
        }

        .user-message {
            background: #004B8D;
            color: white;
            align-self: flex-end;
            box-shadow: 0 0 8px rgba(0, 75, 141, 0.3);
        }

        .chat-form {
            display: flex;
            border-top: 1px solid #ddd;
            background: white;
        }

        .chat-form input {
            flex: 1;
            border: none;
            padding: 15px;
            font-size: 14px;
            outline: none;
        }

        .chat-form button {
            background: #004B8D;
            color: white;
            border: none;
            padding: 15px 20px;
            cursor: pointer;
            transition: background 0.3s;
            font-weight: bold;
        }

        .chat-form button:hover { background: #003366; }

        .typing { font-style: italic; color: #004B8D; }

        .typing .dot {
            animation: blink 1.2s infinite;
            font-weight: bold;
        }

        .typing .dot:nth-child(2) { animation-delay: 0.2s; }
        .typing .dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes blink { 0%, 20%, 100% { opacity: 0; } 50% { opacity: 1; } }

        .department-list {
            margin: 10px 0;
            padding: 0;
            list-style: none;
        }

        .department-list li {
            margin: 5px 0;
            display: flex;
            align-items: center;
        }

        .department-btn {
            background: #004B8D;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 10px;
            font-size: 12px;
            cursor: pointer;
            flex: 1;
            transition: all 0.3s;
        }

        .department-btn:hover { background: #003366; transform: translateY(-2px); }

        .rating-section { margin-top: 10px; }
        .stars-container { text-align: center; font-size: 24px; margin: 10px 0; }
        .star { cursor: pointer; opacity: 0.5; transition: all 0.2s; margin: 0 2px; }
        .star:hover { transform: scale(1.2); }
    </style>
</head>

<body>
    <div class="chat-container">
        <div class="chat-header">Asistente Virtual CIMA</div>

        <div class="chat-box" id="chat-box">
            <div class="bot-message">
                ¡Hola! Soy <b>tu asistente virtual</b> 🐇, de grupo CIMA</b>.<br><br>
                Puedo ayudarte con información sobre:
                <ul class="department-list">
                    <li>📘 <button class="department-btn" onclick="sendQuickMessage('Departamento de Inglés')">Departamento de Inglés</button></li>
                    <li>📗 <button class="department-btn" onclick="sendQuickMessage('Servicios escolares')">Servicios Escolares</button></li>
                    <li>📙 <button class="department-btn" onclick="sendQuickMessage('División de estudios profesionales')">División de Estudios Profesionales</button></li>
                    <li>📕 <button class="department-btn" onclick="sendQuickMessage('Coordinación Ing.Industrial')">Coordinación Ing.Industrial</button></li>
                </ul>
            </div>
        </div>

        <form class="chat-form" id="chat-form">
            <input type="text" id="user-input" placeholder="Escribe tu pregunta aquí..." autocomplete="off" required>
            <button type="submit">Enviar</button>
        </form>
    </div>

    <script>
        const chatBox = document.getElementById("chat-box");
        const input = document.getElementById("user-input");
        const form = document.getElementById("chat-form");

        let calificacionSeleccionada = 0;
        let interacciones = 0;
        let calificacionMostrada = false;

        function addUserMessage(text) {
            const msg = document.createElement("div");
            msg.className = "user-message";
            msg.textContent = text;
            chatBox.appendChild(msg);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function addBotMessage(text) {
            const msg = document.createElement("div");
            msg.className = "bot-message";
            msg.innerHTML = text.replace(/\n/g, "<br>");
            chatBox.appendChild(msg);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function showTypingIndicator() {
            const typing = document.createElement("div");
            typing.className = "bot-message typing";
            typing.innerHTML = "ConejoBot está escribiendo<span class='dot'>.</span><span class='dot'>.</span><span class='dot'>.</span>";
            chatBox.appendChild(typing);
            chatBox.scrollTop = chatBox.scrollHeight;
            return typing;
        }

        async function sendMessageToBot(text) {
            const typing = showTypingIndicator();
            try {
                const res = await fetch("/enviar", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ mensaje: text })
                });
                const data = await res.json();
                chatBox.removeChild(typing);
                addBotMessage(data.respuesta || "Lo siento, no entendí eso 😅");
                interacciones++;
                if (interacciones >= 2 && !calificacionMostrada) mostrarSistemaCalificacion();
            } catch {
                chatBox.removeChild(typing);
                addBotMessage("Error de conexión. Intenta nuevamente.");
            }
        }

        form.addEventListener("submit", e => {
            e.preventDefault();
            const text = input.value.trim();
            if (!text) return;
            addUserMessage(text);
            input.value = "";
            sendMessageToBot(text);
        });

        function sendQuickMessage(text) {
            addUserMessage(text);
            sendMessageToBot(text);
        }

        // ⭐ Sistema de calificación
        function mostrarSistemaCalificacion() {
            if (calificacionMostrada) return;
            const ratingHTML = `
                <div class="rating-section">
                    <div class="bot-message">
                        <strong>¿Cómo calificarías el servicio recibido?</strong><br><br>
                        <div class="stars-container">
                            <span class="star" data-rating="1">⭐</span>
                            <span class="star" data-rating="2">⭐</span>
                            <span class="star" data-rating="3">⭐</span>
                            <span class="star" data-rating="4">⭐</span>
                            <span class="star" data-rating="5">⭐</span>
                        </div><br>
                        <button onclick="enviarCalificacion()" class="rating-btn">Enviar Calificación</button>
                    </div>
                </div>`;
            chatBox.insertAdjacentHTML("beforeend", ratingHTML);
            calificacionMostrada = true;
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        document.addEventListener("click", e => {
            if (e.target.classList.contains("star")) {
                calificacionSeleccionada = parseInt(e.target.dataset.rating);
                document.querySelectorAll(".star").forEach(star => star.style.opacity = "0.5");
                for (let i = 0; i < calificacionSeleccionada; i++) {
                    document.querySelectorAll(".star")[i].style.opacity = "1";
                }
            }
        });

        function enviarCalificacion() {
            if (calificacionSeleccionada === 0) {
                addBotMessage("❌ Por favor selecciona una calificación con las estrellas.");
                return;
            }

            const formData = new FormData();
            formData.append("estrellas", calificacionSeleccionada);

            fetch("/calificar", { method: "POST", body: formData })
                .then(r => r.json())
                .then(data => {
                    let mensaje = "";
                    switch (calificacionSeleccionada) {
                        case 1: mensaje = "😔 Lamentamos que tu experiencia no haya sido buena."; break;
                        case 2: mensaje = "🙁 Gracias, tomaremos en cuenta tus comentarios."; break;
                        case 3: mensaje = "😊 ¡Gracias por tu calificación!"; break;
                        case 4: mensaje = "😄 ¡Excelente! Nos alegra tu experiencia."; break;
                        case 5: mensaje = "🤩 ¡Increíble! Nos encanta saber eso."; break;
                    }
                    addBotMessage(mensaje);
                    document.querySelector(".rating-section").style.display = "none";
                })
                .catch(() => addBotMessage("⚠️ Error al guardar tu calificación."));
        }
    </script>
</body>
</html>







